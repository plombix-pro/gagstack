<div class="mx-auto max-w-5xl">
  <h1 class="mb-6 text-2xl font-bold">Browse Categories</h1>

  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
    <% @categories.each do |category| %>
      <%= link_to category_posts_path(category), class: "group rounded-xl border border-gray-800 bg-gray-900 p-6 text-center transition-colors hover:border-amber-500" do %>
        <span class="text-lg font-semibold text-gray-100 group-hover:text-amber-400"><%= category.name %></span>
        <span class="mt-1 block text-xs text-gray-500"><%= pluralize(category.posts.approved.count, "post") %></span>
      <% end %>
    <% end %>
  </div>
</div>
