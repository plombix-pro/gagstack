<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold mb-6">New Category</h1>

  <%= form_with model: @category, url: admin_categories_path, class: "space-y-4" do |f| %>
    <% if @category.errors.any? %>
      <div class="rounded-lg border border-red-800 bg-red-900/50 p-4">
        <p class="font-semibold mb-1"><%= pluralize(@category.errors.count, "error") %> prevented this category from being saved:</p>
        <ul class="list-disc list-inside text-sm text-red-300">
          <% @category.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= f.text_field :name, class: "w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm text-gray-100 focus:border-amber-500 focus:outline-none" %>
    </div>

    <div>
      <%= f.label :slug, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= f.text_field :slug, class: "w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm text-gray-100 focus:border-amber-500 focus:outline-none" %>
      <p class="text-xs text-gray-500 mt-1">URL-friendly identifier (e.g. "funny-cats")</p>
    </div>

    <div>
      <%= f.label :position, class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= f.number_field :position, class: "w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm text-gray-100 focus:border-amber-500 focus:outline-none" %>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit class: "rounded-lg bg-amber-500 px-6 py-2 text-sm font-semibold text-black hover:bg-amber-400" %>
      <%= link_to "Cancel", admin_categories_path, class: "text-sm text-gray-400 hover:text-gray-300" %>
    </div>
  <% end %>
</div>
