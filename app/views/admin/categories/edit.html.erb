<%= link_to "&larr; Back to Categories".html_safe, admin_categories_path, class: "text-sm text-amber-400 hover:text-amber-300 mb-4 inline-block" %>

<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold mb-6">Edit Category</h1>

  <div class="rounded-xl border border-gray-800 bg-gray-900 p-6">
    <%= form_with model: @category, url: admin_category_path(id: @category.id), method: :patch, class: "space-y-4" do |f| %>
      <% if @category.errors.any? %>
        <div class="rounded-lg border border-red-800 bg-red-900/50 p-4 text-sm text-red-300">
          <p class="font-semibold mb-1"><%= pluralize(@category.errors.count, "error") %> prohibited this category from being saved:</p>
          <ul class="list-disc list-inside">
            <% @category.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.text_field :name, class: "w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm text-white" %>
      </div>

      <div>
        <%= f.label :position, class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.number_field :position, class: "w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm text-white" %>
        <p class="text-xs text-gray-500 mt-1">Lower numbers appear first.</p>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <%= f.submit "Save Changes", class: "rounded-lg bg-amber-500 px-4 py-2 text-sm font-semibold text-black hover:bg-amber-400" %>
        <%= link_to "Cancel", admin_categories_path, class: "rounded-lg bg-gray-800 px-4 py-2 text-sm text-gray-300 hover:bg-gray-700" %>
      </div>
    <% end %>
  </div>
</div>
