<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold mb-6">Reputation Thresholds</h1>
  <div class="space-y-3">
    <% @thresholds.each do |threshold| %>
      <div class="rounded-lg border border-gray-800 bg-gray-900 p-4 flex items-center justify-between">
        <div>
          <h3 class="font-medium text-gray-200"><%= threshold.name.humanize %></h3>
          <p class="text-sm text-gray-500"><%= threshold.description %></p>
        </div>
        <div class="text-right">
          <p class="text-lg font-bold text-amber-400"><%= threshold.min_reputation %></p>
          <p class="text-xs text-gray-500">rep required</p>
          <%= link_to "Edit", edit_admin_reputation_threshold_path(threshold), class: "text-xs text-amber-400 hover:text-amber-300" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
