<div class="max-w-6xl mx-auto">
  <h1 class="text-2xl font-bold mb-6">Search results for "<%= params[:q] %>"</h1>

  <% if @posts.any? %>
    <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
      <%= render partial: "posts/post_card", collection: @posts, as: :post %>
    </div>
  <% else %>
    <p class="text-gray-500 text-center py-12">No results found for "<%= params[:q] %>"</p>
  <% end %>
</div>
