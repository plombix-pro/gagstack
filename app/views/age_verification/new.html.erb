<div class="min-h-[calc(100vh-8rem)] flex items-center justify-center">
  <div class="w-full max-w-lg" data-controller="age-verification" data-age-verification-verified-value="false">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold">Age Verification</h1>
      <p class="text-gray-500 mt-2">You must be 18 or older to use GagStack</p>
    </div>

    <div class="rounded-xl border border-gray-800 bg-gray-900 overflow-hidden">
      <!-- AI verification area -->
      <div data-age-verification-target="aiSection">
        <div class="aspect-[4/3] bg-black relative flex items-center justify-center">
          <video data-age-verification-target="video" autoplay playsinline muted class="w-full h-full object-cover hidden"></video>
          <canvas data-age-verification-target="canvas" class="hidden"></canvas>

          <div class="absolute inset-0 flex items-center justify-center" data-age-verification-target="actions">
            <div class="text-center">
              <svg class="mx-auto h-16 w-16 text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
              <button data-action="age-verification#verify" class="rounded-lg bg-amber-500 px-8 py-3 text-sm font-semibold text-black hover:bg-amber-400 transition-colors">
                Start verification
              </button>
              <p class="text-xs text-gray-600 mt-3">We'll take a photo to estimate your age</p>
              <p class="text-xs text-gray-600">No image is sent to our server — it stays in your browser</p>
              <div class="mt-4">
                <button data-action="age-verification#showManual" class="text-sm text-gray-500 hover:text-gray-300 underline">
                  Or verify manually
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="p-4">
          <div data-age-verification-target="error" class="text-center space-y-3 hidden">
            <p class="text-sm text-red-400">AI model failed to load.</p>
            <button data-action="age-verification#loadModels" class="rounded-lg bg-amber-500 px-6 py-2.5 text-sm font-semibold text-black hover:bg-amber-400 transition-colors">
              Retry loading
            </button>
            <div>
              <button data-action="age-verification#showManual" class="text-sm text-gray-500 hover:text-gray-300 underline">
                Or verify manually
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Manual verification fallback -->
      <div data-age-verification-target="manualSection" class="hidden">
        <div class="p-6 space-y-4">
          <p class="text-sm text-gray-400 text-center">Enter your date of birth to verify your age.</p>

          <div class="grid grid-cols-3 gap-3">
            <div>
              <label class="block text-xs text-gray-500 mb-1">Day</label>
              <select data-age-verification-target="day" class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm text-white">
                <% (1..31).each do |d| %>
                  <option value="<%= d %>"><%= d %></option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Month</label>
              <select data-age-verification-target="month" class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm text-white">
                <% (1..12).each do |m| %>
                  <option value="<%= m %>"><%= Date::MONTHNAMES[m] %></option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Year</label>
              <select data-age-verification-target="year" class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm text-white">
                <% (Date.today.year.downto(Date.today.year - 100)).each do |y| %>
                  <option value="<%= y %>"><%= y %></option>
                <% end %>
              </select>
            </div>
          </div>

          <button data-action="age-verification#verifyManual" class="w-full rounded-lg bg-amber-500 px-6 py-2.5 text-sm font-semibold text-black hover:bg-amber-400 transition-colors">
            Verify age
          </button>

          <div class="text-center">
            <button data-action="age-verification#showAI" class="text-sm text-gray-500 hover:text-gray-300 underline">
              Back to camera verification
            </button>
          </div>
        </div>
      </div>

      <!-- Shared feedback area (always visible) -->
      <div class="p-4">
        <p data-age-verification-target="status" class="text-sm text-gray-400 text-center hidden">
          Initializing...
        </p>

        <div data-age-verification-target="retry" class="text-center hidden">
          <p class="text-sm text-green-400 mb-4 font-medium">Age verified successfully!</p>
          <%= link_to "Continue to sign up", sign_up_path, class: "inline-block rounded-lg bg-amber-500 px-6 py-2.5 text-sm font-semibold text-black hover:bg-amber-400 transition-colors" %>
        </div>

        <div data-age-verification-target="result" class="text-center hidden">
          <p class="text-sm text-red-400 mb-4">Sorry, you must be 18 or older to use GagStack.</p>
          <button data-action="age-verification#verify" class="rounded-lg bg-gray-800 px-6 py-2 text-sm text-gray-300 hover:bg-gray-700 transition-colors">
            Try again
          </button>
        </div>
      </div>
    </div>

    <p class="text-xs text-gray-600 text-center mt-4">
      Age is verified using on-device AI or your date of birth. No biometric data is stored.
    </p>
  </div>
</div>
