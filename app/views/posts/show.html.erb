<div class="max-w-4xl mx-auto">
  <div class="rounded-xl border border-gray-800 bg-gray-900 overflow-hidden">
    <div class="p-4 border-b border-gray-800">
      <div class="flex items-center gap-2 text-xs text-gray-500 mb-2">
        <%= link_to @post.category.name, category_posts_path(@post.category), class: "text-amber-400 hover:text-amber-300" %>
        <span>·</span>
        <span>Posted by <%= link_to @post.user.username, public_profile_path(@post.user.slug), class: "text-gray-500 hover:text-amber-400" %></span>
        <span>·</span>
        <span><%= time_ago_in_words(@post.created_at) %> ago</span>
      </div>
      <h1 class="text-xl font-bold"><%= @post.title %></h1>
    </div>

    <div class="bg-black flex items-center justify-center">
      <% if @post.image? %>
        <%= image_tag @post.media, class: "max-h-[80vh] w-auto", loading: "lazy" %>
      <% elsif @post.gif? %>
        <video autoplay loop muted playsinline class="max-h-[80vh] w-auto" controls>
          <source src="<%= url_for(@post.media) %>" type="video/webm">
        </video>
      <% end %>
    </div>

    <div class="p-4 border-b border-gray-800">
      <div data-post-flag>
        <div class="flex items-center gap-4 text-sm" data-controller="vote" data-vote-post-id-value="<%= @post.id %>">
          <button data-action="vote#up" class="flex items-center gap-1 <%= @post.user_vote(Current.user) == true ? 'text-amber-500' : 'text-gray-400 hover:text-amber-400' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg>
            <span data-vote-target="upvotes"><%= @post.upvotes_count %></span>
          </button>
          <button data-action="vote#down" class="flex items-center gap-1 <%= @post.user_vote(Current.user) == false ? 'text-red-500' : 'text-gray-400 hover:text-red-400' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            <span data-vote-target="downvotes"><%= @post.downvotes_count %></span>
          </button>
          <span class="text-gray-500"><%= @post.comments_count %> comments</span>
          <% if Current.user&.can?(:flag_content) %>
            <span class="ml-auto">
              <a href="#" onclick="this.closest('[data-post-flag]').querySelector('[data-flag-form]').classList.toggle('hidden'); return false;" class="text-xs text-gray-500 hover:text-red-400">Flag</a>
            </span>
          <% end %>
        </div>
        <% if Current.user&.can?(:flag_content) %>
          <div class="hidden mt-2" data-flag-form>
            <div class="rounded-lg border border-gray-700 bg-gray-900 p-3">
              <%= form_with url: post_flags_path(@post), local: true do %>
                <%= text_area_tag "flag[reason]", nil, placeholder: "Why is this inappropriate?", class: "w-full rounded bg-gray-800 border border-gray-700 text-sm p-2 text-gray-200", rows: 2 %>
                <%= submit_tag "Submit flag", class: "mt-2 rounded bg-red-700 px-3 py-1 text-xs text-white hover:bg-red-600 cursor-pointer" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-6">
    <h2 class="text-lg font-semibold mb-4">Comments</h2>
    <div id="comment_form">
      <% if Current.user %>
        <%= render partial: "comments/form", locals: { post: @post, comment: @comment } %>
      <% else %>
        <p class="text-sm text-gray-500 mb-6"><%= link_to "Login", sign_in_path, class: "text-amber-400 hover:text-amber-300" %> to comment.</p>
      <% end %>
    </div>

    <div class="space-y-4" id="comments_<%= @post.id %>">
      <% if @comments.present? %>
        <%= render partial: "comments/comment_tree", locals: { comments: @comments } %>
      <% else %>
        <p class="text-sm text-gray-500">No comments yet.</p>
      <% end %>
    </div>
  </div>
</div>
