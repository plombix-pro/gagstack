<div class="min-h-[calc(100vh-8rem)] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold">Join GagStack</h1>
      <p class="text-gray-500 mt-2">Create an account to start posting</p>
    </div>

    <%= form_with model: @user, url: registrations_path, local: true, class: "space-y-5" do |form| %>
      <% if @user.errors.any? %>
        <div class="rounded-lg bg-red-900/30 border border-red-800 p-4">
          <ul class="text-sm text-red-400 space-y-1">
            <% @user.errors.full_messages.each do |msg| %>
              <li>• <%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :username, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </span>
          <%= form.text_field :username, required: true, placeholder: "Choose a username", class: "w-full rounded-lg border border-gray-700 bg-gray-800 pl-10 pr-3 py-2.5 text-sm text-gray-100 placeholder-gray-500 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
        </div>
      </div>

      <div>
        <%= form.label :email_address, "Email", class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </span>
          <%= form.email_field :email_address, required: true, placeholder: "you@example.com", class: "w-full rounded-lg border border-gray-700 bg-gray-800 pl-10 pr-3 py-2.5 text-sm text-gray-100 placeholder-gray-500 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
        </div>
      </div>

      <div>
        <%= form.label :date_of_birth, "Date of birth", class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </span>
          <%= form.date_field :date_of_birth, required: true, max: 18.years.ago.to_date.iso8601, class: "w-full rounded-lg border border-gray-700 bg-gray-800 pl-10 pr-3 py-2.5 text-sm text-gray-100 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
        </div>
        <p class="mt-1 text-xs text-gray-500">You must be 18 or older to use GagStack</p>
      </div>

      <div>
        <%= form.label :password, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </span>
          <%= form.password_field :password, required: true, placeholder: "Min 6 characters", class: "w-full rounded-lg border border-gray-700 bg-gray-800 pl-10 pr-3 py-2.5 text-sm text-gray-100 placeholder-gray-500 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
        </div>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-gray-300 mb-1.5" %>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </span>
          <%= form.password_field :password_confirmation, placeholder: "Repeat password", class: "w-full rounded-lg border border-gray-700 bg-gray-800 pl-10 pr-3 py-2.5 text-sm text-gray-100 placeholder-gray-500 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500" %>
        </div>
      </div>

      <%= form.submit "Create account", class: "w-full rounded-lg bg-amber-500 px-4 py-2.5 text-sm font-semibold text-black hover:bg-amber-400 transition-colors" %>
    <% end %>

    <p class="mt-6 text-sm text-gray-500 text-center">
      Already have an account?
      <%= link_to "Log in", sign_in_path, class: "text-amber-400 hover:text-amber-300 font-medium" %>
    </p>
  </div>
</div>
