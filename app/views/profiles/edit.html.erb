<div class="mx-auto max-w-2xl">
  <h1 class="text-2xl font-bold mb-6">Settings</h1>

  <%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-8" do |f| %>
    <% if @user.errors.any? %>
      <div class="rounded-lg border border-red-800 bg-red-900/50 p-4">
        <p class="font-semibold mb-1"><%= pluralize(@user.errors.count, "error") %>:</p>
        <ul class="list-disc list-inside text-sm text-red-300">
          <% @user.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Avatar -->
    <div class="rounded-xl border border-gray-800 bg-gray-900 p-6">
      <h2 class="text-lg font-semibold mb-4">Avatar</h2>
      <div class="flex items-center gap-6">
        <%= avatar_tag(@user, size: 80, show_dots: true, earned: @earned) %>
        <div>
          <%= f.file_field :avatar, accept: "image/*", class: "text-sm text-gray-400 file:mr-3 file:rounded-lg file:border-0 file:bg-gray-800 file:px-3 file:py-1.5 file:text-sm file:text-gray-300 hover:file:bg-gray-700" %>
          <p class="text-xs text-gray-500 mt-1">PNG, JPG or GIF. Max 5MB.</p>
        </div>
      </div>
    </div>

    <!-- Username -->
    <div class="rounded-xl border border-gray-800 bg-gray-900 p-6">
      <h2 class="text-lg font-semibold mb-4">Username</h2>
      <div>
        <%= f.text_field :username,
          class: "w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm text-gray-100 focus:border-amber-500 focus:outline-none #{'opacity-50 cursor-not-allowed' unless @user.can?(:change_username)}",
          disabled: !@user.can?(:change_username) %>
        <% unless @user.can?(:change_username) %>
          <p class="text-xs text-amber-500 mt-1">Requires 500 reputation to change username.</p>
        <% end %>
      </div>
    </div>

    <!-- Email -->
    <div class="rounded-xl border border-gray-800 bg-gray-900 p-6">
      <h2 class="text-lg font-semibold mb-4">Email</h2>
      <p class="text-sm text-gray-400 mb-3">Current: <%= @user.email_address %></p>
      <% if @user.pending_email_change? %>
        <div class="rounded-lg border border-amber-800 bg-amber-900/30 p-3 mb-3 text-sm">
          Verification sent to <strong><%= @user.unconfirmed_email %></strong>.
          Check your inbox to confirm. <%= link_to "Cancel", cancel_email_change_profile_path, data: { turbo_method: :post }, class: "text-amber-400 hover:text-amber-300 underline" %>
        </div>
      <% end %>
      <%= f.email_field :email_address, placeholder: "New email address",
        class: "w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm text-gray-100 focus:border-amber-500 focus:outline-none" %>
      <p class="text-xs text-gray-500 mt-1">A verification link will be sent to the new address. Can be changed once per week.</p>
    </div>

    <!-- Password -->
    <div class="rounded-xl border border-gray-800 bg-gray-900 p-6">
      <h2 class="text-lg font-semibold mb-4">Password</h2>
      <div class="space-y-3">
        <div>
          <%= f.label :current_password, class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.password_field :current_password, class: "w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm text-gray-100 focus:border-amber-500 focus:outline-none" %>
        </div>
        <div>
          <%= f.label :password, "New password", class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.password_field :password, class: "w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm text-gray-100 focus:border-amber-500 focus:outline-none" %>
        </div>
        <div>
          <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.password_field :password_confirmation, class: "w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm text-gray-100 focus:border-amber-500 focus:outline-none" %>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit "Save changes", class: "rounded-lg bg-amber-500 px-6 py-2 text-sm font-semibold text-black hover:bg-amber-400" %>
      <%= link_to "Cancel", public_profile_path(@user.slug), class: "text-sm text-gray-400 hover:text-gray-300" %>
    </div>
  <% end %>
</div>
